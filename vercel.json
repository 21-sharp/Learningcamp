{
    "version": 2,
    "builds": [
        {
            "src": "Backend/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "Backend/server.js"
        },
        {
            "src": "/(static/.*)",
            "dest": "/frontend/$1"
        },
        {
            "src": "/(.*\\.(png|jpg|jpeg|gif|svg|ico|json|css|js|map))$",
            "dest": "/frontend/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/index.html"
        }
    ]
}